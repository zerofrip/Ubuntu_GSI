#!/bin/sh
# =============================================================================
# /init (Next-Generation UHL Multi-Stage Bootloader)
# =============================================================================
# Custom Linux init acting as PID 1 to explicitly drop Android constraints.
# Stages: Vendor Mount -> BinderFS -> UHL Daemons -> Dynamic RootFS -> Systemd
# =============================================================================

export PATH=/sbin:/bin:/usr/sbin:/usr/bin

echo "[UHL Boot] Stage 1: Initializing Virtual Filesystems..."
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t devpts devpts /dev/pts

echo "[UHL Boot] Stage 2: Mounting Android Vendor Boundaries..."
mkdir -p /vendor
mount -t ext4 -o ro /dev/block/bootdevice/by-name/vendor /vendor 2>/dev/null || \
    mount -t ext4 -o ro /dev/block/mapper/vendor /vendor

echo "[UHL Boot] Stage 3: Initializing BinderFS IPC..."
mkdir -p /dev/binderfs
mount -t binder binder /dev/binderfs
symlink /dev/binderfs/binder /dev/binder
symlink /dev/binderfs/vndbinder /dev/vndbinder
symlink /dev/binderfs/hwbinder /dev/hwbinder
chmod 0666 /dev/binder /dev/vndbinder /dev/hwbinder

echo "[UHL Boot] Stage 4: Preparing Universal HAL Layer (UHL) endpoints..."
mkdir -p /dev/uhl
chmod 0755 /dev/uhl
# UHL services will naturally bind to these pipes when systemd executes

echo "[UHL Boot] Stage 5: Configuring Dynamic RootFS via OverlayFS..."
# We expect the payload block to be mapped natively over /data/linux_rootfs.squashfs
mkdir -p /data
# Example mounting, real logic assumes fstab triggers userdata
mount -t ext4 /dev/block/bootdevice/by-name/userdata /data 2>/dev/null

BASE="/rootfs/ubuntu-base"
UPPER="/data/uhl_overlay/upper"
WORK="/data/uhl_overlay/work"
MERGED="/rootfs/merged"

mkdir -p "$BASE" "$UPPER" "$WORK" "$MERGED"

# If squashfs exists, mount it to base natively
if [ -f "/data/linux_rootfs.squashfs" ]; then
    mount -t squashfs -o loop /data/linux_rootfs.squashfs "$BASE"
else
    echo "[UHL Boot] FATAL: Squashfs payload missing from /data/linux_rootfs.squashfs"
fi

mount -t overlay overlay -o lowerdir="$BASE",upperdir="$UPPER",workdir="$WORK" "$MERGED"

# Bind critical hardware API pathways into the new root
mkdir -p "$MERGED/vendor" "$MERGED/dev/binderfs" "$MERGED/dev/uhl"
mount --bind /vendor "$MERGED/vendor"
mount --bind /dev/binderfs "$MERGED/dev/binderfs"
mount --bind /dev/uhl "$MERGED/dev/uhl"

echo "[UHL Boot] Stage 6: Bounding PID 1 over to Linux systemd (switch_root)..."
exec switch_root "$MERGED" /lib/systemd/systemd --log-target=kmsg
