# =============================================================================
# ubuntu-universal.rc (Universal Next Architecture 15-18+)
# =============================================================================
# Minimal Android init mapping designed to remain compatible indefinitely by 
# offloading all complex routing to the systemd/android-bridge stack natively.
# =============================================================================

import /system/etc/init/ubuntu-universal.rc

on early-init
    # Establish exclusively BinderFS bindings (Legacy binder dropped)
    mkdir /dev/binderfs 0755 root root
    mount binder binder /dev/binderfs stats=global
    symlink /dev/binderfs/binder /dev/binder
    symlink /dev/binderfs/vndbinder /dev/vndbinder
    chmod 0666 /dev/binder
    chmod 0666 /dev/vndbinder

on init
    # Configure base dynamic partition mappings
    mkdir /overlay 0755 root root
    mount overlay overlay /overlay
    
    # Establish Universal Structure mapping
    mkdir /ubuntu 0755 root root
    mkdir /ubuntu/rootfs 0755 root root
    mkdir /ubuntu/writable 0755 root root
    mkdir /android/container 0755 root root
    
    # Systemd Bootstrap
    start systemd-boot

on late-init
    trigger post-fs
    trigger post-fs-data

on post-fs
    mount none /system /system remount ro

on post-fs-data
    # Bind Vendor layout provided by hardware OEMs
    mount none /vendor /android/container/vendor bind

service systemd-boot /sbin/init
    class core
    user root
    group root
    critical
    seclabel u:r:init:s0
