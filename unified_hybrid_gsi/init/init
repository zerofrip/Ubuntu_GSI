#!/bin/sh
# =============================================================================
# /init (Unified Modular GSI Init)
# =============================================================================

export PATH=/sbin:/bin:/usr/sbin:/usr/bin

echo "[Unified Init] Stage 1 - Base Virtual Layers..."
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t devpts devpts /dev/pts

echo "[Unified Init] Stage 2 - Android Ext4 Vendor Matrix..."
mkdir -p /vendor
mount -t ext4 -o ro /dev/block/bootdevice/by-name/vendor /vendor 2>/dev/null || \
    mount -t ext4 -o ro /dev/block/mapper/vendor /vendor

# Triggering hardware discovery prior to Pivot preventing /system payload pollution
echo "[Unified Init] Stage 3 - Vendor Hardware Auto-Discovery..."
chmod +x /scripts/*.sh
/scripts/detect-gpu.sh

echo "[Unified Init] Stage 4 - Binder IPC & HAF Setup..."
mkdir -p /dev/binderfs
mount -t binder binder /dev/binderfs
symlink /dev/binderfs/binder /dev/binder
symlink /dev/binderfs/vndbinder /dev/vndbinder
symlink /dev/binderfs/hwbinder /dev/hwbinder
chmod 0666 /dev/binder /dev/vndbinder /dev/hwbinder

echo "[Unified Init] Handing execution loop to mount.sh Pivot sequence..."
exec /init/mount.sh
