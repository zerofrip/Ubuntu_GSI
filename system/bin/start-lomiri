#!/bin/bash
# =============================================================================
# start-lomiri
# =============================================================================
# This script initializes the Mir and Lomiri UI stack within the Ubuntu
# Touch container overlay.

echo "[start-lomiri] Preparing graphical environment..."

export XDG_RUNTIME_DIR=/run/user/$(id -u ubuntu)
mkdir -p "$XDG_RUNTIME_DIR"
chown ubuntu:ubuntu "$XDG_RUNTIME_DIR"
chmod 0700 "$XDG_RUNTIME_DIR"

# Basic wayland variables
export WAYLAND_DISPLAY=wayland-0
export MIR_SERVER_WAYLAND_HOST=wayland-0

# Set default driver if KMS allows direct discovery, or fallback to mesa/gbm
export MIR_SERVER_GRAPHICS_PLATFORM=mesa 

echo "[start-lomiri] Handing off to ubuntu user..."

# Drop to standard user session
exec su - ubuntu -c "
    export XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR
    export WAYLAND_DISPLAY=wayland-0
    export MIR_SERVER_WAYLAND_HOST=wayland-0
    export QT_QPA_PLATFORM=wayland

    echo 'Starting Mir compositor...'
    miral-app -kiosk &
    sleep 3

    echo 'Starting Lomiri desktop session...'
    exec lomiri
"
