#!/system/bin/sh
# =============================================================================
# start-ubuntu-container
# =============================================================================
# Wrapper script to prepare the environment and launch the Ubuntu LXC container.
# This script is executed by Android init.

echo "[start-ubuntu-container] Preparing environment..."

# Ensure DRM and Input devices are accessible to the container
if [ -d /dev/dri ]; then
    chmod 0666 /dev/dri/* 2>/dev/null || true
fi

if [ -d /dev/graphics ]; then
    chmod 0666 /dev/graphics/* 2>/dev/null || true
fi

if [ -d /dev/input ]; then
    chmod 0666 /dev/input/* 2>/dev/null || true
fi

echo "[start-ubuntu-container] Launching LXC..."

# Exec into lxc-start to replace this script process
exec /system/bin/lxc-start \
    -n ubuntu \
    -f /system/etc/lxc/ubuntu/config \
    -o /data/lxc/ubuntu/lxc.log \
    -l INFO \
    -F
