# =============================================================================
# LXC Container Configuration — Ubuntu on Android GSI
# =============================================================================
#
# Container: ubuntu
# Purpose:   Run Ubuntu userspace with systemd as init, isolated from Android
#            vendor partition, with controlled binder IPC access.
#
# Security model:
#   - Namespace isolation: PID, mount, network, IPC, UTS, user
#   - Capability dropping: CAP_SYS_ADMIN, CAP_SYS_MODULE, CAP_NET_RAW
#   - Seccomp profile restricting dangerous syscalls
#   - SELinux domain: ubuntu_container_t
#   - No access to /vendor, /odm, /product
#   - Only /dev/binder exposed (no hwbinder, vndbinder)
# =============================================================================

# ---- General ----
lxc.uts.name = ubuntu
lxc.arch = aarch64

# ---- Rootfs with OverlayFS ----
# Lower layer: read-only Ubuntu base rootfs
# Upper layer: writable overlay for apt/user changes
# This allows apt upgrades without reflashing the system partition
lxc.rootfs.path = overlay:lowerdir=/system/ubuntu-rootfs:upperdir=/data/ubuntu/overlay:workdir=/data/ubuntu/workdir
lxc.rootfs.options = nosuid,nodev

# ---- Init ----
# systemd as PID 1 inside the container
lxc.init.cmd = /sbin/init

# ---- Namespace isolation ----
lxc.namespace.keep =

# ---- Network ----
# Virtual ethernet pair for isolated networking
lxc.net.0.type = veth
lxc.net.0.flags = up
lxc.net.0.name = eth0
lxc.net.0.link = lxcbr0
lxc.net.0.ipv4.address = 10.0.3.100/24
lxc.net.0.ipv4.gateway = 10.0.3.1
lxc.net.0.mtu = 1500

# ---- Mount entries ----
# Essential pseudo-filesystems (auto-mounted by LXC)
lxc.mount.auto = proc:mixed sys:ro cgroup:mixed

# Bind mount /dev/binder from host into container
# This is the ONLY binder device exposed — no hwbinder, no vndbinder
lxc.mount.entry = /dev/binder dev/binder none bind,create=file 0 0

# Expose /dev/null, /dev/zero, /dev/urandom, /dev/random
lxc.mount.entry = /dev/null dev/null none bind,create=file 0 0
lxc.mount.entry = /dev/zero dev/zero none bind,create=file 0 0
lxc.mount.entry = /dev/urandom dev/urandom none bind,create=file 0 0
lxc.mount.entry = /dev/random dev/random none bind,create=file 0 0

# tmpfs for /run and /tmp inside container
lxc.mount.entry = tmpfs run tmpfs rw,nosuid,nodev,mode=0755 0 0
lxc.mount.entry = tmpfs tmp tmpfs rw,nosuid,nodev 0 0

# Bind mount /dev/dri and /dev/input for native Mir execution
lxc.mount.entry = /dev/dri dev/dri none bind,optional,create=dir 0 0
lxc.mount.entry = /dev/input dev/input none bind,optional,create=dir 0 0

# Bind mount start-lomiri script to rootfs
lxc.mount.entry = /system/bin/start-lomiri start-lomiri none bind,ro,create=file 0 0

# Shared memory for systemd
lxc.mount.entry = tmpfs dev/shm tmpfs rw,nosuid,nodev,noexec,mode=1777,size=65536k 0 0

# ---- EXPLICITLY DENIED MOUNTS ----
# /vendor is NEVER mounted. Ubuntu must not access vendor blobs.
# /odm is NEVER mounted.
# /product is NEVER mounted.
# /dev/hwbinder is NEVER mounted.
# /dev/vndbinder is NEVER mounted.

# ---- Capabilities ----
# Drop dangerous capabilities
lxc.cap.drop = sys_admin
lxc.cap.drop = sys_module
lxc.cap.drop = sys_rawio
lxc.cap.drop = net_raw
lxc.cap.drop = sys_boot
lxc.cap.drop = sys_ptrace
lxc.cap.drop = mknod

# Keep only what Ubuntu needs to function
lxc.cap.keep = chown
lxc.cap.keep = dac_override
lxc.cap.keep = fowner
lxc.cap.keep = fsetid
lxc.cap.keep = kill
lxc.cap.keep = setgid
lxc.cap.keep = setuid
lxc.cap.keep = setpcap
lxc.cap.keep = net_bind_service
lxc.cap.keep = net_admin
lxc.cap.keep = sys_chroot
lxc.cap.keep = sys_nice
lxc.cap.keep = sys_resource
lxc.cap.keep = audit_write
lxc.cap.keep = setfcap
lxc.cap.keep = ipc_lock
lxc.cap.keep = ipc_owner

# ---- Seccomp ----
lxc.seccomp.profile = /system/etc/seccomp/ubuntu_container.json

# ---- SELinux ----
lxc.selinux.context = system_u:system_r:ubuntu_container_t:s0

# ---- cgroup limits ----
# Limit memory to 75% of available RAM (adjust per device)
lxc.cgroup2.memory.max = 3G
lxc.cgroup2.memory.swap.max = 512M

# CPU limits — container gets fair share but cannot starve host
lxc.cgroup2.cpu.weight = 100
lxc.cgroup2.cpu.max = 800000 1000000

# Limit PIDs to prevent fork bombs
lxc.cgroup2.pids.max = 4096

# ---- Device access control (cgroup) ----
# Deny all devices by default
lxc.cgroup2.devices.deny = a

# Allow only specific devices:
# /dev/null (1:3), /dev/zero (1:5), /dev/random (1:8), /dev/urandom (1:9)
lxc.cgroup2.devices.allow = c 1:3 rwm
lxc.cgroup2.devices.allow = c 1:5 rwm
lxc.cgroup2.devices.allow = c 1:8 rwm
lxc.cgroup2.devices.allow = c 1:9 rwm

# /dev/binder — character device, major 10 (misc), minor varies
# Using wildcard for minor since binderfs assigns dynamically
lxc.cgroup2.devices.allow = c 10:* rwm

# /dev/pts (PTY) — needed for terminal access
lxc.cgroup2.devices.allow = c 136:* rwm
lxc.cgroup2.devices.allow = c 5:2 rwm

# /dev/tty
lxc.cgroup2.devices.allow = c 5:0 rwm

# Graphics & Input Devices
# /dev/dri (char 226:*)
lxc.cgroup2.devices.allow = c 226:* rwm
# /dev/input (char 13:*)
lxc.cgroup2.devices.allow = c 13:* rwm

# ---- Console ----
lxc.console.size = auto
lxc.tty.max = 4
lxc.pty.max = 1024

# ---- Logging ----
lxc.log.level = INFO
lxc.log.file = /data/lxc/ubuntu/lxc.log

# ---- AppArmor (disable — we use SELinux) ----
lxc.apparmor.profile = unconfined

# ---- Misc ----
lxc.signal.halt = SIGRTMIN+3
lxc.signal.reboot = SIGTERM
