# =============================================================================
# ubuntu.config (Hybrid LXC Isolation Payload)
# =============================================================================

lxc.uts.name = ubuntu-touch
lxc.arch = arm64

# Base Storage mapping natively over standard paths
lxc.rootfs.path = overlay:/ubuntu/rootfs:/ubuntu/writable

# Primary Isolation Elements
lxc.seccomp.profile = /system/etc/lxc/seccomp_hybrid.json

# Explicit Mount Proxy Definitions securing hardware endpoints
lxc.mount.entry = /dev /dev none bind,create=dir 0 0
lxc.mount.entry = /sys /sys none bind,create=dir 0 0
lxc.mount.entry = /proc /proc none bind,create=dir 0 0

# Bind BinderFS securely mapped natively from PID 1 wrapper
lxc.mount.entry = /dev/binderfs/binder /dev/binder none bind,create=file 0 0
lxc.mount.entry = /dev/binderfs/vndbinder /dev/vndbinder none bind,create=file 0 0

# Character Device Access (DRM/GPU/Input/Audio)
lxc.cgroup.devices.allow = c 226:* rwm  # /dev/dri
lxc.cgroup.devices.allow = c 13:* rwm   # /dev/input
lxc.cgroup.devices.allow = c 116:* rwm  # ALSA audio

# Drop highly vulnerable native capabilities ensuring Android Host remains safe
lxc.cap.drop = sys_module
lxc.cap.drop = mac_admin
lxc.cap.drop = mac_override
lxc.cap.drop = ptrace
lxc.cap.drop = sys_time
lxc.cap.drop = sys_rawio
